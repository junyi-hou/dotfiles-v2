OPENACP_CONFIG_PATH="$HOME/.config/openacp/config.json"
export OPENACP_CONFIG_PATH

SOPS_AGE_KEY_FILE="$HOME/.config/age/key"
export SOPS_AGE_KEY_FILE

PATH="$HOME/dotfiles-v2/.pixi/envs/all/bin:$HOME/.local/bin:/bin:$PATH"

if [ -d "$HOME/dotfiles-v2/.tools/java" ]; then
    JAVA_HOME=$HOME/dotfiles-v2/.tools/java
    PATH="$JAVA_HOME/bin:$PATH"
    export JAVA_HOME
fi

export PATH

