#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

ENC_FILE = Path.home() / "dotfiles-v2" / "env.json.enc"


def decrypt(enc_file: Path) -> dict:
    result = subprocess.run(
        [
            "sops",
            "--decrypt",
            "--input-type",
            "json",
            "--output-type",
            "json",
            str(enc_file),
        ],
        capture_output=True,
        check=True,
    )
    return json.loads(result.stdout)


def lookup(data: dict, path: str):
    current = data
    for key in path.split("/"):
        if not isinstance(current, dict) or key not in current:
            print(f"key not found: {path}", file=sys.stderr)
            sys.exit(1)
        current = current[key]
    return current


def main():
    if not ENC_FILE.exists():
        print("Cannot find the encrypted env file, exiting", file=sys.stderr)
        sys.exit(1)

    data = decrypt(ENC_FILE)

    if len(sys.argv) == 1:
        print(json.dumps(data, indent=2))
    else:
        value = lookup(data, sys.argv[1])
        print(value if isinstance(value, str) else json.dumps(value, indent=2))


if __name__ == "__main__":
    main()
