#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from pathlib import Path

ENC_FILE = Path.home() / "dotfiles-v2" / "env.json.enc"


def decrypt(enc_file: Path) -> dict:
    result = subprocess.run(
        [
            "sops",
            "--decrypt",
            "--input-type",
            "json",
            "--output-type",
            "json",
            str(enc_file),
        ],
        capture_output=True,
        check=True,
    )
    return json.loads(result.stdout)


def main():
    args = sys.argv[1:]

    if not args:
        print("usage: run-with-env [ENV...] -- <command> [args...]", file=sys.stderr)
        print("       run-with-env <command> [args...]", file=sys.stderr)
        sys.exit(1)

    if "--" in args:
        sep = args.index("--")
        env_keys = args[:sep]
        cmd_args = args[sep + 1 :]
        if not cmd_args:
            print("usage: run-with-env [ENV...] -- <command> [args...]", file=sys.stderr)
            sys.exit(1)
    else:
        env_keys = []
        cmd_args = args

    if not ENC_FILE.exists():
        print("Cannot find the encrypted env file, exiting", file=sys.stderr)
        sys.exit(1)

    data = decrypt(ENC_FILE)

    if env_keys:
        extra = {}
        for key in env_keys:
            if key not in data["env"]:
                print(f"warning: ENV key '{key}' not found in encrypted env file", file=sys.stderr)
            else:
                extra[key] = data["env"][key]
        env = {**os.environ, **extra}
    else:
        env = {**os.environ, **data["env"]}

    os.execvpe(cmd_args[0], cmd_args, env)


if __name__ == "__main__":
    main()
