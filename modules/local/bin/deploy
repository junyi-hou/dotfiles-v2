#!/usr/bin/env python3

import argparse
import subprocess
from pathlib import Path

DOTFILES_DIR = Path(__file__).resolve().parents[3]
ENC_FILE = DOTFILES_DIR / "env.json.enc"
LOCAL_KEY_PATH = Path.home() / ".config" / "age" / "key"
REMOTE_DOTFILES = "~/dotfiles-v2"
REMOTE_REPO = "https://github.com/junyi-hou/dotfiles-v2"
REMOTE_KEY_PATH = f"{REMOTE_DOTFILES}/keys/age"
REMOTE_ENC_PATH = f"{REMOTE_DOTFILES}/env.json.enc"


def parse_args():
    parser = argparse.ArgumentParser(description="Deploy dotfiles to a remote host")
    parser.add_argument("target", help="user@host")
    parser.add_argument("-p", "--port", type=int, default=22)
    parser.add_argument("--secret-only", action="store_true")
    return parser.parse_args()


def run(cmd, **kwargs):
    return subprocess.run(cmd, check=True, **kwargs)


def get_local_public_key() -> str:
    for line in LOCAL_KEY_PATH.read_text().splitlines():
        if line.startswith("# public key:"):
            return line.split(": ", 1)[1].strip()
    raise RuntimeError(f"No public key found in {LOCAL_KEY_PATH}")


def generate_age_key() -> tuple[str, str]:
    result = subprocess.run(["rage-keygen"], capture_output=True, text=True, check=True)
    lines = result.stdout.strip().splitlines()
    public_key = next(
        line.split(": ", 1)[1] for line in lines if line.startswith("# public key:")
    )
    private_key = next(line for line in lines if line.startswith("AGE-SECRET-KEY-"))
    return public_key, private_key


def reencrypt_for(public_key: str) -> bytes:
    if not ENC_FILE.exists():
        raise RuntimeError(f"Encrypted secrets not found: {ENC_FILE}\nRun sops-edit-secret in Emacs to create it.")
    decrypted = subprocess.run(
        ["sops", "--decrypt", "--input-type", "json", "--output-type", "json", str(ENC_FILE)],
        capture_output=True, check=True,
    ).stdout
    return subprocess.run(
        ["sops", "--encrypt", "--age", public_key,
         "--input-type", "json", "--output-type", "json", "/dev/stdin"],
        input=decrypted, capture_output=True, check=True,
    ).stdout


def remote_clone(target: str, port: int):
    run(["ssh", "-p", str(port), target, f"git clone {REMOTE_REPO} {REMOTE_DOTFILES}"])


def deploy_secret(target: str, port: int):
    print("Generating age key for remote...")
    public_key, private_key = generate_age_key()
    print(f"Public key: {public_key}")

    print("Re-encrypting secrets for remote key...")
    encrypted = reencrypt_for(public_key)

    print("Copying age key to remote...")
    run(
        ["ssh", "-p", str(port), target,
         f"mkdir -p $(dirname {REMOTE_KEY_PATH}) && cat > {REMOTE_KEY_PATH} && chmod 600 {REMOTE_KEY_PATH}"],
        input=(private_key + "\n").encode(),
    )

    print("Copying encrypted secrets to remote...")
    run(
        ["ssh", "-p", str(port), target, f"cat > {REMOTE_ENC_PATH}"],
        input=encrypted,
    )


def main():
    args = parse_args()

    if not args.secret_only:
        print(f"Cloning dotfiles on {args.target}...")
        remote_clone(args.target, args.port)

    deploy_secret(args.target, args.port)

    print("Done.")


if __name__ == "__main__":
    main()
