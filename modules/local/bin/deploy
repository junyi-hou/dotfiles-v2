#!/usr/bin/env python3

import argparse
import subprocess


REMOTE_DOTFILES = "~/dotfiles-v2"
REMOTE_REPO = "https://github.com/junyi-hou/dotfiles-v2"


def parse_args():
    parser = argparse.ArgumentParser(description="Deploy dotfiles to a remote host")
    parser.add_argument("target", help="user@host")
    parser.add_argument("-p", "--port", type=int, default=22)
    parser.add_argument("-b", "--build", action="store_true")
    return parser.parse_args()


def run(cmd, **kwargs):
    return subprocess.run(cmd, check=True, **kwargs)


def check_remote_deps(target: str, port: int):
    run(
        [
            "ssh",
            "-p",
            str(port),
            target,
            "command -v git || { echo 'git not found'; exit 1; }; "
            "command -v direnv || { echo 'direnv not found'; exit 1; }; "
            "ldconfig -p 2>/dev/null | grep -q libfuse || { echo 'libfuse not found'; exit 1; }",
        ]
    )


def remote_clone(target: str, port: int):
    run(["ssh", "-p", str(port), target, f"git clone {REMOTE_REPO} {REMOTE_DOTFILES}"])


def remote_build(target: str, port: int):
    run(
        [
            "ssh",
            "-p",
            str(port),
            target,
            f"cd {REMOTE_DOTFILES} && direnv allow && direnv exec {REMOTE_DOTFILES} make install && direnv exec {REMOTE_DOTFILES} make build",
        ]
    )


def main():
    args = parse_args()

    print(f"Checking remote dependencies on {args.target}...")
    check_remote_deps(args.target, args.port)
    print(f"Cloning dotfiles on {args.target}...")
    remote_clone(args.target, args.port)

    if args.build:
        print(f"Building dotfiles on {args.target}...")
        remote_build(args.target, args.port)

    print("Done.")


if __name__ == "__main__":
    main()
