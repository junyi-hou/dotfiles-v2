#!/usr/bin/env python3

import argparse
import subprocess
from pathlib import Path


REMOTE_DOTFILES = "~/dotfiles-v2"
REMOTE_REPO = "https://github.com/junyi-hou/dotfiles-v2"
LOCAL_DOTFILES = Path(__file__).resolve().parents[3]


def parse_args():
    parser = argparse.ArgumentParser(description="Deploy dotfiles to a remote host")
    parser.add_argument("target", help="user@host")
    parser.add_argument("-p", "--port", type=int, default=22)
    parser.add_argument("-b", "--build", action="store_true")
    parser.add_argument("-i", "--install", action="store_true")
    parser.add_argument("--use-local-copy", action="store_true")
    return parser.parse_args()


def run(cmd, **kwargs):
    return subprocess.run(cmd, check=True, **kwargs)


def check_remote_deps(target: str, port: int):
    run(
        [
            "ssh",
            "-p",
            str(port),
            target,
            "command -v git || { echo 'git not found'; exit 1; }; "
            "command -v direnv || { echo 'direnv not found'; exit 1; }; "
            "ldconfig -p 2>/dev/null | grep -q libfuse || { echo 'libfuse not found'; exit 1; }",
        ]
    )


def remote_clone(target: str, port: int, use_local_copy: bool):
    if use_local_copy:
        run(
            [
                "rsync",
                "-a",
                "--delete",
                "--filter=:- .gitignore",
                "-e",
                f"ssh -p {port}",
                f"{LOCAL_DOTFILES}/",
                f"{target}:{REMOTE_DOTFILES}",
            ]
        )
    else:
        run(
            [
                "ssh",
                "-p",
                str(port),
                target,
                f"git clone {REMOTE_REPO} {REMOTE_DOTFILES}",
            ]
        )


def remote_build(target: str, port: int):
    run(
        [
            "ssh",
            "-p",
            str(port),
            target,
            f"cd {REMOTE_DOTFILES} && direnv allow && direnv exec {REMOTE_DOTFILES} make build",
        ]
    )


def remote_install(target: str, port: int):
    run(
        [
            "ssh",
            "-p",
            str(port),
            target,
            f"cd {REMOTE_DOTFILES} && direnv allow && direnv exec {REMOTE_DOTFILES} make install",
        ]
    )


def main():
    args = parse_args()

    print(f"Checking remote dependencies on {args.target}...")
    check_remote_deps(args.target, args.port)
    print(f"Cloning dotfiles on {args.target}...")
    remote_clone(args.target, args.port, args.use_local_copy)

    if args.build:
        # build implies install
        print(f"Installing dotfiles on {args.target}...")
        remote_install(args.target, args.port)

        print(f"Building dotfiles on {args.target}...")
        remote_build(args.target, args.port)

    if args.install:
        print(f"Installing dotfiles on {args.target}...")
        remote_install(args.target, args.port)

    print("Done.")


if __name__ == "__main__":
    main()
